# Variables de entorno para la aplicación de inventario

########################
# Base de datos local  #
########################
# Host de la base de datos local
DB_HOST=localhost
# Puerto de la base de datos local
DB_PORT=3306
# Usuario con permisos de lectura/escritura
DB_USER=root
# Contraseña del usuario
DB_PASSWORD=
# Nombre de la base de datos
DB_NAME=inventario_retail_one

########################
# Sesiones de Express  #
########################
# Secreto para firmar las cookies de sesión
SESSION_SECRET=cambia_esto_por_un_valor_mas_seguros

###########################################
# Base de datos remota para sincronización #
###########################################
# Host de la base remota (proyecto Soporte 360)
REMOTE_DB_HOST=hopper.proxy.rlwy.net
# Puerto de la base remota
REMOTE_DB_PORT=18688
# Usuario de la base remota
REMOTE_DB_USER=root
# Contraseña del usuario remoto
REMOTE_DB_PASSWORD=
# Nombre de la base de datos remota
REMOTE_DB_NAME=railway

#################################################
# Límite de conexiones opcional para pools MySQL #
#################################################
DB_CONNECTION_LIMIT=10
REMOTE_DB_CONNECTION_LIMIT=5