<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title || 'Inventario Electronico' %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="<%= currentPath === '/login' ? 'login-page' : 'app-page' %>">
  <header class="topbar">
    <div class="container topbar-inner">
      <a href="/dashboard" class="brand">
        <span class="brand-mark">▣</span>
        <span>Inventario Electronico</span>
      </a>

      <% if (currentUser) {
        const isControlRole = ['admin', 'manager'].includes(currentUser.rol);
        const countIsActive = currentPath === '/dashboard' || currentPath.startsWith('/inventarios');
      %>
        <nav class="nav" aria-label="Principal">
          <% if (isControlRole) { %>
            <a class="nav-link nav-link-home <%= currentPath === '/dashboard' ? 'active' : '' %>" href="/dashboard">
              <span class="nav-icon">⌂</span>
              <span>Inicio</span>
            </a>
            <a class="nav-link nav-link-home <%= currentPath.startsWith('/inventarios') ? 'active' : '' %>" href="/dashboard#inventarios-panel">
              <span class="nav-icon">🧾</span>
              <span>Inventarios</span>
            </a>
          <% } else { %>
            <a class="nav-link nav-link-home <%= countIsActive ? 'active' : '' %>" href="/dashboard">
              <span class="nav-icon">🧾</span>
              <span>Contar</span>
            </a>
          <% } %>

          <a class="nav-link nav-link-stock <%= currentPath === '/existencias' ? 'active' : '' %>" href="/existencias">
            <span class="nav-icon">📦</span>
            <span>Existencias</span>
          </a>
        </nav>

        <div class="topbar-user">
          <span class="user-badge">
            <strong><%= currentUser.username %></strong>
            <small><%= currentUser.rol %></small>
          </span>

          <form action="/logout" method="post">
            <button type="submit" class="btn btn-secondary btn-sm">
              <span class="btn-icon">⇦</span>
              <span>Salir</span>
            </button>
          </form>
        </div>
      <% } %>
    </div>
  </header>

  <main class="container page">
    <% if (flash) { %>
      <div class="alert alert-<%= flash.type %>"><%= flash.text %></div>
    <% } %>
