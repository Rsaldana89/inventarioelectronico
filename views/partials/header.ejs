<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title || 'Inventario Retail One' %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header class="topbar">
    <div class="container topbar-inner">
      <a href="/dashboard" class="brand">Inventario Retail One</a>

      <% if (currentUser) { %>
        <nav class="nav">
          <a class="<%= currentPath === '/dashboard' || currentPath === '/inventarios' ? 'active' : '' %>" href="/dashboard">Dashboard</a>
          <a class="<%= currentPath === '/existencias' ? 'active' : '' %>" href="/existencias">Existencias</a>
        </nav>

        <div class="topbar-user">
          <span class="user-badge">
            <strong><%= currentUser.username %></strong>
            <small><%= currentUser.rol %></small>
          </span>

          <form action="/logout" method="post">
            <button type="submit" class="btn btn-secondary btn-sm">Salir</button>
          </form>
        </div>
      <% } %>
    </div>
  </header>

  <main class="container page">
    <% if (flash) { %>
      <div class="alert alert-<%= flash.type %>"><%= flash.text %></div>
    <% } %>
