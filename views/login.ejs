<%- include('partials/header', { title: title }) %>

<section class="login-wrapper">
  <div class="card login-card">
    <h1>Iniciar sesion</h1>
    <p class="muted">Acceso simple con usuario y contrasena.</p>

    <form action="/login" method="post" class="form-grid">
      <label>
        Usuario
        <input type="text" name="username" placeholder="admin" required autofocus data-autofocus>
      </label>

      <label>
        Contrasena
        <input type="password" name="password" placeholder="********" required>
      </label>

      <button type="submit" class="btn btn-primary">Entrar</button>
    </form>

    <div class="hint">
      <strong>Credenciales iniciales:</strong><br>
      admin / admin123
    </div>
  </div>
</section>

<%- include('partials/footer') %>
