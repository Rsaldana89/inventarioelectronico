<%- include('partials/header', { title: title }) %>
<%
  const isControlRole = currentUser && ['admin', 'manager'].includes(currentUser.rol);
  const openInventario = (inventarios || []).find((item) => item.estado === 'abierto');
  const recentInventarios = (inventarios || []).slice(0, 8);
%>

<% if (!isControlRole) { %>
  <section class="page-header page-header-home store-landing-header">
    <div>
      <span class="section-kicker section-kicker-home">Conteo para sucursal</span>
      <h1>Contar inventario</h1>
      <p class="muted">Entra, crea el inventario y empieza a capturar. Si necesitas una base, administración deberá haber cargado la proforma del mes.</p>
    </div>
    <div class="page-header-actions">
      <!-- Para sucursales, se oculta la carga de proformas.  Solo se permite imprimir si existe una -->
      <% if ((cargasExistencia || []).length) { %>
        <a class="btn btn-secondary" href="/proforma/imprimir"><span class="btn-icon">🖨️</span><span>Imprimir proforma</span></a>
      <% } %>
      <% if (openInventario) { %>
        <a class="btn btn-primary" href="/inventarios/<%= openInventario.id %>"><span class="btn-icon">▶</span><span>Continuar conteo</span></a>
      <% } %>
    </div>
  </section>

  <section class="store-hero-grid">
    <article class="card section-card section-card-home store-primary-card">
      <div class="card-heading">
        <div>
          <span class="section-kicker">Paso principal</span>
          <h2><%= openInventario ? 'Tienes un inventario abierto' : 'Crear inventario nuevo' %></h2>
          <p class="muted small">
            <% if (openInventario) { %>
              El sistema detectó un inventario pendiente para que sigas contando sin perder tiempo.
            <% } else { %>
              Elige la fecha y decide si contarás libremente o con base en una existencia ya cargada.
            <% } %>
          </p>
        </div>
        <span class="heading-icon">🧾</span>
      </div>

      <% if (openInventario) { %>
        <div class="store-open-highlight">
          <div>
            <strong>Inventario #<%= openInventario.id %></strong>
            <p class="muted small">
              <%= openInventario.sucursal_nombre %> ·
              Creado <%= formatDateTime(openInventario.created_at) %> ·
              <%= ['con_existencia', 'con_existencias'].includes(openInventario.origen_existencias) ? 'Con proforma' : 'Conteo libre' %>
            </p>
          </div>
          <span class="pill pill-open">abierto</span>
        </div>
        <div class="store-action-stack">
          <a class="btn btn-primary btn-lg" href="/inventarios/<%= openInventario.id %>"><span class="btn-icon">▶</span><span>Continuar inventario</span></a>
          <a class="btn btn-secondary" href="/inventarios/<%= openInventario.id %>/imprimir?tipo=sku" target="_blank"><span class="btn-icon">🖨️</span><span>Imprimir inventario</span></a>
          <a class="btn btn-secondary" href="#crear-nuevo"><span class="btn-icon">＋</span><span>Crear otro inventario</span></a>
        </div>
      <% } %>

      <form method="post" action="/inventarios" class="form-grid" id="crear-nuevo">
        <label>
          Fecha
          <input type="date" name="fecha" value="<%= new Date().toISOString().slice(0, 10) %>" required>
        </label>

          <label>
            Tipo de conteo
            <select name="origen_existencias" id="origen_existencias" data-origen-select>
              <% var tieneProforma = hasProformaThisMonth; %>
              <option value="sin_existencias" <%= tieneProforma ? '' : 'selected' %>>Conteo libre, sin proforma</option>
              <option value="con_existencia" <%= tieneProforma ? 'selected' : '' %>>Basado en proforma cargada</option>
            </select>
          </label>

        <label data-existencia-wrapper>
          Fecha de proforma
          <select name="existencia_carga_id" id="existencia_carga_id" data-existencia-select>
            <option value="">Selecciona la proforma</option>
            <% (cargasExistencia || []).forEach(function(carga, idx) { %>
              <option value="<%= carga.id %>" <%= idx === 0 ? 'selected' : '' %>>Proforma cargada <%= formatDateTime(carga.created_at) %></option>
            <% }) %>
          </select>
        </label>

        <% if (hasProformaThisMonth) { %>
          <button type="submit" class="btn btn-primary btn-primary-cta btn-lg"><span class="btn-icon">▶</span><span>Crear y empezar a contar</span></button>
        <% } else { %>
          <button type="button" class="btn btn-primary btn-primary-cta btn-lg" disabled><span class="btn-icon">🚫</span><span>Crear y empezar a contar</span></button>
          <p class="muted small">No hay proforma cargada este mes. Espera a que administración la cargue.</p>
        <% } %>
      </form>
    </article>
    <!-- Se oculta la sección de carga de proforma para sucursales -->
    <% /* Mostrar un recuadro informativo para sucursales sobre la proforma del mes */ %>
    <article class="card section-card section-card-stock store-secondary-card">
      <div class="card-heading">
        <div>
          <span class="section-kicker section-kicker-stock">Base de existencias</span>
          <h2>Proforma del mes</h2>
          <% if (hasProformaThisMonth) { %>
            <p class="muted small">Hay una proforma cargada para este mes. Puedes imprimirla para utilizarla como referencia al contar.</p>
          <% } else { %>
            <p class="muted small">No hay una proforma cargada para este mes todavía. Comunícate con administración para que la cargue.</p>
          <% } %>
        </div>
        <span class="heading-icon stock-icon">📦</span>
      </div>
      <% if (hasProformaThisMonth && (cargasExistencia || []).length) { %>
        <div class="store-action-stack">
          <a class="btn btn-secondary" href="/proforma/imprimir"><span class="btn-icon">🖨️</span><span>Imprimir proforma</span></a>
        </div>
      <% } %>
    </article>
  </section>

  <section class="cards-grid store-summary-grid">
    <article class="card stat-card stat-card-home"><span class="stat-label">Inventarios</span><strong class="stat-value"><%= summary.total || 0 %></strong></article>
    <article class="card stat-card stat-card-home"><span class="stat-label">Abiertos</span><strong class="stat-value"><%= summary.abiertos || 0 %></strong></article>
    <article class="card stat-card stat-card-home"><span class="stat-label">Cerrados</span><strong class="stat-value"><%= summary.cerrados || 0 %></strong></article>
  </section>

  <section class="card section-card section-card-home">
    <div class="card-heading">
      <div>
        <span class="section-kicker">Recientes</span>
        <h2>Inventarios de la sucursal</h2>
      </div>
      <span class="heading-icon">📋</span>
    </div>
    <div class="table-responsive">
        <table class="data-table">
        <thead>
          <tr><th>ID</th><th>Creado</th><th>Fecha</th><th>Base</th><th>Estado</th><th>Registros</th><th>Unidades</th><th>Acción</th></tr>
        </thead>
        <tbody>
          <% if (!recentInventarios.length) { %>
            <tr><td colspan="8" class="empty-cell">Todavía no hay inventarios para esta sucursal.</td></tr>
          <% } %>
          <% recentInventarios.forEach(function eachInventario(inventario) { %>
            <tr>
              <td>#<%= inventario.id %></td>
              <td><%= formatDateTime(inventario.created_at) %></td>
              <td><%= formatDate(inventario.fecha) %></td>
              <td><%= ['con_existencia', 'con_existencias'].includes(inventario.origen_existencias) ? 'Con proforma' : 'Libre' %></td>
              <td><span class="pill <%= inventario.estado === 'abierto' ? 'pill-open' : 'pill-closed' %>"><%= inventario.estado %></span></td>
              <td><%= inventario.registros_capturados %></td>
              <td><%= formatQty(inventario.unidades_capturadas) %></td>
              <td>
                <div class="actions-row">
                  <a class="btn btn-secondary btn-sm" href="/inventarios/<%= inventario.id %>"><span class="btn-icon">→</span><span>Abrir</span></a>
                  <a class="btn btn-secondary btn-sm" href="/inventarios/<%= inventario.id %>/imprimir?tipo=sku" target="_blank"><span class="btn-icon">🖨️</span><span>Imprimir</span></a>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
        </table>
    </div>
  </section>
<% } else { %>
  <section class="page-header page-header-home">
    <div>
      <span class="section-kicker section-kicker-home">Panel principal</span>
      <h1>Inicio</h1>
      <p class="muted">Elige una acción. Desde aquí puedes contar, consultar, cargar proformas y concentrar la operación del sistema.</p>
    </div>
  </section>

  <section class="action-grid">
    <a class="card action-card action-card-home" href="#crear-inventario-panel">
      <span class="action-icon">🧾</span>
      <strong>Contar inventario</strong>
      <p>Crear un inventario nuevo y comenzar la captura.</p>
    </a>
    <a class="card action-card action-card-neutral" href="#inventarios-panel">
      <span class="action-icon">🔎</span>
      <strong>Consultar inventarios</strong>
      <p>Filtrar, revisar estados y abrir conteos existentes.</p>
    </a>
    <a class="card action-card action-card-stock" href="/proforma">
      <span class="action-icon">📥</span>
      <strong>Cargar proforma</strong>
      <p>Subir archivos por sucursal para usarlos como base.</p>
    </a>
    <a class="card action-card action-card-admin" href="#administracion-panel">
      <span class="action-icon">⚙</span>
      <strong>Administrar sistema</strong>
      <p>Concentrar filtros, sucursales y accesos de operación.</p>
    </a>
  </section>

  <section class="cards-grid">
    <article class="card stat-card stat-card-home"><span class="stat-label">Inventarios totales</span><strong class="stat-value"><%= summary.total || 0 %></strong></article>
    <article class="card stat-card stat-card-home"><span class="stat-label">Abiertos</span><strong class="stat-value"><%= summary.abiertos || 0 %></strong></article>
    <article class="card stat-card stat-card-home"><span class="stat-label">Cerrados</span><strong class="stat-value"><%= summary.cerrados || 0 %></strong></article>
  </section>

  <section class="two-column dashboard-main-grid">
    <article class="card section-card section-card-home" id="crear-inventario-panel">
      <div class="card-heading">
        <div>
          <span class="section-kicker">Contar</span>
          <h2>Crear inventario</h2>
        </div>
        <span class="heading-icon">＋</span>
      </div>
      <form method="post" action="/inventarios" class="form-grid compact-grid">
        <% if (['admin','manager'].includes(currentUser.rol)) { %>
          <label>
            Sucursal
            <select name="sucursal_id" required>
              <% sucursales.forEach(function eachSucursal(sucursal) { %>
                <option value="<%= sucursal.id %>" <%= String(filters.sucursalId || '') === String(sucursal.id) ? 'selected' : '' %>><%= sucursal.nombre %></option>
              <% }) %>
            </select>
          </label>
        <% } %>

        <label>
          Fecha
          <input type="date" name="fecha" value="<%= new Date().toISOString().slice(0, 10) %>" required>
        </label>

        <label>
          Tipo de conteo
          <select name="origen_existencias" id="origen_existencias" data-origen-select>
            <% var tieneProformaCtrl = (cargasExistencia || []).length > 0; %>
            <option value="sin_existencias" <%= tieneProformaCtrl ? '' : 'selected' %>>Conteo libre</option>
            <option value="con_existencia" <%= tieneProformaCtrl ? 'selected' : '' %>>Basado en proforma</option>
          </select>
        </label>

        <label data-existencia-wrapper>
          Proforma
          <select name="existencia_carga_id" id="existencia_carga_id" data-existencia-select>
            <option value="">Selecciona la proforma</option>
            <% (cargasExistencia || []).forEach(function(carga, idx) { %>
              <option value="<%= carga.id %>" <%= idx === 0 ? 'selected' : '' %>>#<%= carga.id %> · Cargada <%= formatDateTime(carga.created_at) %></option>
            <% }) %>
          </select>
        </label>

        <button type="submit" class="btn btn-primary"><span class="btn-icon">▶</span><span>Crear inventario</span></button>
      </form>
      <p class="muted small">La proforma solo se activa cuando el conteo es basado en proforma.</p>
    </article>

    <article class="card section-card section-card-home" id="administracion-panel">
      <div class="card-heading">
        <div>
          <span class="section-kicker">Administración</span>
          <h2>Centro de operación</h2>
        </div>
        <span class="heading-icon">⚙</span>
      </div>
      <div class="admin-info-grid">
        <div class="admin-info-box">
          <span class="admin-info-label">Usuario</span>
          <strong><%= currentUser.username %></strong>
        </div>
        <div class="admin-info-box">
          <span class="admin-info-label">Rol</span>
          <strong><%= currentUser.rol %></strong>
        </div>
        <div class="admin-info-box">
          <span class="admin-info-label">Acceso principal</span>
          <strong><%= ['admin','manager'].includes(currentUser.rol) ? 'Todas las sucursales' : 'Operación asignada' %></strong>
        </div>
      </div>
      <div class="admin-shortcuts">
        <a class="btn btn-secondary" href="#inventarios-panel"><span class="btn-icon">🔎</span><span>Ir a consulta</span></a>
        <a class="btn btn-stock" href="/proforma"><span class="btn-icon">📥</span><span>Ir a proformas</span></a>
      </div>
      <div class="hint compact-hint">
        <strong>Flujo sugerido</strong>
        <span>1. Cargar proforma</span>
        <span>2. Crear inventario</span>
        <span>3. Abrir y contar</span>
        <span>4. Consultar resultados</span>
      </div>
    </article>
  </section>

  <section class="card section-card section-card-home" id="inventarios-panel">
    <div class="card-heading">
      <div>
        <span class="section-kicker">Consulta</span>
        <h2>Inventarios</h2>
      </div>
      <span class="heading-icon">📋</span>
    </div>

    <form method="get" action="/dashboard" class="form-grid compact-grid dashboard-filter-row">
      <% if (['admin','manager'].includes(currentUser.rol)) { %>
        <label>
          Sucursal
          <select name="sucursal_id">
            <option value="">Todas</option>
            <% sucursales.forEach(function eachSucursal(sucursal) { %>
              <option value="<%= sucursal.id %>" <%= String(filters.sucursalId || '') === String(sucursal.id) ? 'selected' : '' %>><%= sucursal.nombre %></option>
            <% }) %>
          </select>
        </label>
      <% } %>
      <label>Fecha inicial<input type="date" name="fecha_inicio" value="<%= filters.fechaInicio %>"></label>
      <label>Fecha final<input type="date" name="fecha_fin" value="<%= filters.fechaFin %>"></label>
      <button type="submit" class="btn btn-secondary"><span class="btn-icon">🔎</span><span>Aplicar filtro</span></button>
    </form>

    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr><th>ID</th><th>Creado</th><th>Fecha</th><th>Sucursal</th><th>Base</th><th>Estado</th><th>Registros</th><th>Unidades</th><th>Acciones</th></tr>
        </thead>
        <tbody>
          <% if (!inventarios.length) { %>
            <tr><td colspan="9" class="empty-cell">No hay inventarios con los filtros seleccionados.</td></tr>
          <% } %>
          <% inventarios.forEach(function eachInventario(inventario) { %>
            <tr>
              <td>#<%= inventario.id %></td>
              <td><%= formatDateTime(inventario.created_at) %></td>
              <td><%= formatDate(inventario.fecha) %></td>
              <td><%= inventario.sucursal_nombre %></td>
              <td><%= ['con_existencia', 'con_existencias'].includes(inventario.origen_existencias) ? 'Con proforma' : 'Sin proforma' %></td>
              <td><span class="pill <%= inventario.estado === 'abierto' ? 'pill-open' : 'pill-closed' %>"><%= inventario.estado %></span></td>
              <td><%= inventario.registros_capturados %></td>
              <td><%= formatQty(inventario.unidades_capturadas) %></td>
              <td>
                <div class="actions-row">
                  <a class="btn btn-secondary btn-sm" href="/inventarios/<%= inventario.id %>"><span class="btn-icon">→</span><span>Abrir</span></a>
                  <a class="btn btn-secondary btn-sm" href="/inventarios/<%= inventario.id %>/imprimir?tipo=sku" target="_blank"><span class="btn-icon">🖨️</span><span>Imprimir</span></a>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
<% } %>

<%- include('partials/footer') %>
