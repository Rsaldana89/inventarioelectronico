<%- include('partials/header', { title: title }) %>

<section class="page-header">
  <div>
    <h1>Existencias</h1>
    <p class="muted">Solo se manejan SKU numericos entre 1100000 y 2200000. Cada carga de existencias se guarda por sucursal y fecha.</p>
  </div>
</section>

<section class="two-column">
  <article class="card">
    <h2>Seleccion de sucursal</h2>

    <form method="get" action="/existencias" class="form-grid compact-grid">
      <label>
        Sucursal
        <select name="sucursal_id" required>
          <% sucursales.forEach(function eachSucursal(sucursal) { %>
            <option value="<%= sucursal.id %>" <%= String(selectedSucursalId || '') === String(sucursal.id) ? 'selected' : '' %>><%= sucursal.nombre %></option>
          <% }) %>
        </select>
      </label>

      <label>
        Buscar
        <input type="text" name="search" value="<%= filters.search %>" placeholder="Barcode, codigo o descripcion">
      </label>

      <button type="submit" class="btn btn-secondary">Consultar</button>
    </form>
  </article>

  <article class="card">
    <h2>Importar existencias</h2>

    <form method="post" action="/upload-existencias" enctype="multipart/form-data" class="form-grid compact-grid">
      <input type="hidden" name="sucursal_id" value="<%= selectedSucursalId || '' %>">

      <label>
        Fecha de existencia
        <input type="date" name="fecha_existencia" value="<%= new Date().toISOString().slice(0, 10) %>" required>
      </label>

      <label>
        Archivo XLS / XLSX
        <input type="file" name="archivo" accept=".xls,.xlsx,.csv" required>
      </label>

      <button type="submit" class="btn btn-primary">Cargar existencias</button>
    </form>

    <p class="muted small">La carga actualiza la existencia visible de la sucursal y además guarda el corte con su fecha para poder iniciar inventarios basados en esa fecha.</p>
  </article>
</section>

<% if (currentUser.rol === 'admin') { %>
  <section class="card">
    <h2>Actualizar catalogo de productos</h2>

    <form method="post" action="/upload-productos" enctype="multipart/form-data" class="form-grid compact-grid">
      <label>
        Archivo TXT / XLS / XLSX
        <input type="file" name="archivo" accept=".txt,.xls,.xlsx,.csv" required>
      </label>

      <button type="submit" class="btn btn-secondary">Cargar catalogo</button>
    </form>

    <form method="post" action="/delete-productos" data-confirm="Se eliminara todo el catalogo actual.">
      <button type="submit" class="btn btn-danger">Borrar catalogo actual</button>
    </form>

    <p class="muted small">Solo se conservan SKU numericos dentro del rango 1100000 a 2200000.</p>

    <% if (catalogUpdatedAt) { %>
      <p class="muted small">Última actualización: <%= formatDate(catalogUpdatedAt) %></p>
    <% } else { %>
      <p class="muted small">Aún no se ha importado un catálogo de productos.</p>
    <% } %>
  </section>
<% } %>

<section class="cards-grid">
  <article class="card stat-card"><span class="stat-label">Sucursal activa</span><strong class="stat-value"><%= sucursalActual ? sucursalActual.nombre : 'Sin seleccionar' %></strong></article>
  <article class="card stat-card"><span class="stat-label">Items cargados</span><strong class="stat-value"><%= summary.items || 0 %></strong></article>
  <article class="card stat-card"><span class="stat-label">Unidades totales</span><strong class="stat-value"><%= formatQty(summary.unidades || 0) %></strong></article>
  <article class="card stat-card"><span class="stat-label">Catalogo</span><strong class="stat-value"><%= productCount || 0 %></strong></article>
</section>

<section class="card">
  <h2>Fechas de existencias cargadas</h2>
  <div class="table-responsive">
    <table class="data-table">
      <thead><tr><th>ID corte</th><th>Fecha de existencia</th><th>Fecha y hora de carga</th></tr></thead>
      <tbody>
        <% if (!cargasExistencia.length) { %>
          <tr><td colspan="3" class="empty-cell">Aún no hay cortes cargados para esta sucursal.</td></tr>
        <% } %>
        <% cargasExistencia.forEach(function(carga) { %>
          <tr>
            <td>#<%= carga.id %></td>
            <td><%= formatDate(carga.fecha_existencia) %></td>
            <td><%= formatDateTime(carga.created_at) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section class="card">
  <h2>Detalle de existencias</h2>
  <div class="table-responsive">
    <table class="data-table">
      <thead><tr><th>Codigo</th><th>Barcode</th><th>Descripcion</th><th>Cantidad</th></tr></thead>
      <tbody>
        <% if (!existencias.length) { %>
          <tr><td colspan="4" class="empty-cell">No hay existencias para mostrar. Importa un archivo para la sucursal seleccionada.</td></tr>
        <% } %>
        <% existencias.forEach(function eachExistencia(item) { %>
          <tr>
            <td><%= item.codigo || '-' %></td>
            <td><%= item.barcode %></td>
            <td><%= item.descripcion || '-' %></td>
            <td><%= formatQty(item.cantidad) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <%- include('partials/pagination', { pagination: pagination, basePath: '/existencias', baseQuery: baseQuery }) %>
</section>

<%- include('partials/footer') %>
